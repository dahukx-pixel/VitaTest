<UserControl x:Class="VitaTest.Modules.Incomes.Views.IncomesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:VitaTest.Modules.Incomes.Views"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="300"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True" 
             xmlns:converters="clr-namespace:VitaTest.AppCore.Converters;assembly=VitaTest.AppCore">

    <UserControl.Resources>
        <converters:ValueIsZeroConverter x:Key="ValueIsZeroConverter"/>
    </UserControl.Resources>

    <materialDesign:DialogHost CloseOnClickAway="True">

        <materialDesign:DialogHost.DialogContent>
            <StackPanel Margin="20">

                <StackPanel.Resources>
                    <Style TargetType="TextBlock">
                        <Setter Property="FontSize" Value="17"/>
                    </Style>
                </StackPanel.Resources>

                <StackPanel Orientation="Horizontal"
                            Margin="0, 0, 0, 10">
                    <materialDesign:PackIcon Kind="AccountBalanceWalletOutline"
                                             Width="40"
                                             Height="40"
                                             VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Пополнить баланс"
                                   FontWeight="Bold"/>
                        <TextBlock Text="Укажите сумму для пополнения"
                                   Margin="0, 0, 0, 10"/>
                    </StackPanel>
                </StackPanel>
                <TextBox Text="{Binding IncomeSum}"
                         materialDesign:HintAssist.Hint="Сумма пополнения"
                         FontSize="17"
                         Margin="0, 0, 0, 30"/>
                <Button Content="Пополнить"
                        Foreground="White"
                        HorizontalAlignment="Center"
                        Command="{Binding AddIncomeCommand}"/>
            </StackPanel>
        </materialDesign:DialogHost.DialogContent>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="100"/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <DockPanel VerticalAlignment="Center"
                       Margin="20,0,0,0">
                    <materialDesign:PackIcon Kind="AccountBalanceWallet"
                                 Height="30"
                                 Width="30"
                                 VerticalAlignment="Center"
                                 Margin="0,0,5,0"
                                 Background="{StaticResource HeaderIconColor}"
                                 Foreground="White"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="История пополнений"
                       Style="{StaticResource MaterialDesignHeadline5TextBlock}"
                       FontWeight="Bold"/>
                        <TextBlock Text="История и пополнение баланса"/>
                    </StackPanel>
                </DockPanel>

                <Button HorizontalAlignment="Right"
                    Margin="0, 0, 20, 0"
                    VerticalAlignment="Center"
                    Command="{x:Static materialDesign:DialogHost.OpenDialogCommand}">
                    <Button.Content>
                        <DockPanel>
                            <materialDesign:PackIcon Kind="Add"
                                                 Margin="0, 0, 5, 0"
                                                 VerticalAlignment="Center"
                                                 Foreground="White"/>
                            <TextBlock Text="Пополнить"
                                   VerticalAlignment="Center"
                                   Foreground="White"/>
                        </DockPanel>
                    </Button.Content>
                </Button>
            </Grid>

            <DataGrid ItemsSource="{Binding Incomes}"
                      Margin="10"
                      CanUserAddRows="False"
                      AutoGenerateColumns="False"
                      Grid.Row="1">

                <DataGrid.Columns>
                    <materialDesign:DataGridTextColumn Header="№"
                                                       Binding="{Binding ID}"/>
                    <materialDesign:DataGridTextColumn Header="Сумма"
                                                       Binding="{Binding Amount}"
                                                       FontWeight="Bold"/>
                    <materialDesign:DataGridTextColumn Header="Остаток"
                                                       Binding="{Binding Balance}"/>
                    <DataGridTemplateColumn Header="Статус">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <materialDesign:Chip>
                                    <materialDesign:Chip.Content>
                                        <TextBlock FontWeight="Bold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="Активно"/>
                                                    <Setter Property="Foreground" Value="#008080"/>

                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Balance, Converter={StaticResource ValueIsZeroConverter}}" 
                                                                     Value="True">
                                                            <Setter Property="Text" Value="Израсходовано"/>
                                                            <Setter Property="Foreground" Value="#8B0000"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </materialDesign:Chip.Content>
                                </materialDesign:Chip>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <materialDesign:DataGridTextColumn Header="Обновлено"
                                                       Binding="{Binding UpdatedAt, StringFormat=dd.MM.yyyy hh:mm:ss}"/>
                    <materialDesign:DataGridTextColumn Header="Создано"
                                                       Binding="{Binding CreatedAt, StringFormat=dd.MM.yyyy hh:mm:ss}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </materialDesign:DialogHost>
</UserControl>
